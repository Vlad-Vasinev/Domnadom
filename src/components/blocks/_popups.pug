
<template id="consult-form">
  <div class="popup _catalog-popup" data-lenis-prevent>
    <div class="popup__close">
      <div class="popup__close-svg">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M11.9991 13.0607L5.52941 19.5303L4.46875 18.4697L10.9384 12L4.46875 5.53033L5.52941 4.46967L11.9991 10.9393L18.4688 4.46967L19.5294 5.53033L13.0597 12L19.5294 18.4697L18.4688 19.5303L11.9991 13.0607Z" fill="#0D0D0D"/>
        </svg>
      </div>
    </div>
    <div class="popup__body">
      .catalog-form
        form.form(data-action="/api/consult-form" data-thanks-url="/thanks.html")
          .text-xlBold Project consultation
          .text-l
            |Submit a request, and a Terem specialist will consult you on everything from installment plans to construction timelines.
          <div id="smartcaptcha" class="smart-captcha"></div>
          <div class="form__block">
            <input type="text" required placeholder="" name="name" />
            <label class="text-label"> your name *</label>
          </div>
          <div class="form__block">
            <input type="text" required placeholder="" name="phone" />
            <label class="text-label">phone</label>
          </div>
          <div class="form__block _checkbox">
            <label>
              <input type="checkbox" placeholder="" name="permission" />
              <span></span>
              .text-s I agree to the Personal Data Processing Policy and the processing of personal data
            </label>
          </div>
          button.button-m.primary-btn(type="submit") Send
    </div>
  </div>
</template>

